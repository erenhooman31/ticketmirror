DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_LOG_LEVEL=INFO
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
ALLOWED_HOSTS=tickets.example.com
CSRF_TRUSTED_ORIGINS=https://tickets.example.com

DOMAIN=tickets.example.com
ACME_EMAIL=admin@example.com

POSTGRES_DB=ticketmirror
POSTGRES_USER=ticketmirror
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgres://ticketmirror:replace-with-a-strong-database-password@postgres:5432/ticketmirror

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

GMAIL_MAILBOX=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_PUBSUB_TOPIC=
GMAIL_WEBHOOK_AUDIENCE=
GOOGLE_CLOUD_PROJECT=
